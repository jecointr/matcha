# Environment
NODE_ENV=development

# Database
DB_USER=matcha_user
DB_PASSWORD=your_secure_password_here_change_me
DB_NAME=matcha_db
DB_HOST=db
DB_PORT=5432

# JWT - IMPORTANT: Change this to a random 64+ character string in production!
JWT_SECRET=change_this_to_a_very_long_random_string_at_least_64_characters_long
JWT_EXPIRES_IN=7d

# Mail (utiliser maildev en dev, configurer SMTP réel en prod)
MAIL_HOST=maildev
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@matcha.local

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=http://localhost:3000

# ============================================
# PRODUCTION SETTINGS (uncomment and configure)
# ============================================
# NODE_ENV=production
# DB_PASSWORD=super_secure_production_password
# JWT_SECRET=your_production_jwt_secret_64_chars_minimum
# MAIL_HOST=smtp.yourprovider.com
# MAIL_PORT=587
# MAIL_USER=your_email@domain.com
# MAIL_PASSWORD=your_email_password
# MAIL_FROM=noreply@yourdomain.com
# FRONTEND_URL=https://yourdomain.com
# BACKEND_URL=https://api.yourdomain.com

GOOGLE_CLIENT_ID=ton_google_client_id
GOOGLE_CLIENT_SECRET=ton_google_client_secret

GITHUB_CLIENT_ID=ton_github_client_id
GITHUB_CLIENT_SECRET=ton_github_client_secret